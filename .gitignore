# Archivos generados por el compilador
*.o
*.obj
*.so
*.exe
*.out
*.app
*.dSYM/

# Archivos temporales de compilación
*.a
*.lib
*.dll

# Archivos de dependencias generados
*.d

# Archivos de CMake (si usas CMake)
CMakeCache.txt
CMakeFiles/
Makefile
cmake_install.cmake

# Archivos de IDEs comunes
.vscode/
.idea/
*.swp
*.swo
*.log

# Archivos de configuración específicos de Visual Studio
.vs/
.vscode/

# Archivos de compilación específicos de Xcode
build/
*.xcuserstate

# Archivos generados por Clion
.idea/
cmake-build-*/

# Otros archivos de configuración del proyecto (dependiendo de tu entorno)
*.iml
